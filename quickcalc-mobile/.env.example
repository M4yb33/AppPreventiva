# ════════════════════════════════════════════════════════════════
# API Configuration - QuickCalc Mobile
# ════════════════════════════════════════════════════════════════

# OPCIÓN 1: Misma WiFi (Mejor para desarrollo local)
# Reemplaza 192.168.x.x con tu IP real
# Windows: ipconfig | findstr "IPv4"
# Mac/Linux: ifconfig | grep "inet "
# EXPO_PUBLIC_API_URL=http://192.168.18.9:3000/api

# OPCIÓN 2: Expo Tunnel (Funciona desde cualquier red)
# Usa localhost, Expo configurará el túnel automáticamente
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# OPCIÓN 3: ngrok (Más potente, requiere instalación)
# Después de ejecutar: ngrok http 3000
# EXPO_PUBLIC_API_URL=https://abc123def456.ngrok.io/api

# OPCIÓN 4: URL remota (Si tu backend está en un servidor)
# EXPO_PUBLIC_API_URL=https://api.ejemplo.com/api
